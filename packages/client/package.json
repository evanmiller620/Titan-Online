{
  "name": "@titan/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Titan web client. React UI + PixiJS board rendering, strictly decoupled from the @titan/engine rules. Subscribes to Supabase Realtime for authoritative state; submits commands and waits (strict-wait v1) for the reconciled broadcast.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:offline": "tsc -p tsconfig.offline.json",
    "typecheck:logic": "tsc -p tsconfig.logic.json",
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "dependencies": {
    "@titan/engine": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "pixi.js": "^8.2.0",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "@vitejs/plugin-react": "^4.3.0"
  }
}